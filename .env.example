# Recordinjho secrets — copy to `.env` and fill in. `.env` is git-ignored.
# Load into your shell with:  set -a; source .env; set +a

# AssemblyAI (Stage 2 transcription) — https://www.assemblyai.com/app
ASSEMBLYAI_API_KEY=

# Anthropic / Claude (Stage 2 summary) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional overrides
# RECORDINJHO_MODEL=claude-sonnet-4-6
# ASSEMBLYAI_LANGUAGE=hr        # force a language code (omit = English)
# ASSEMBLYAI_LANG_DETECT=true   # or auto-detect language
